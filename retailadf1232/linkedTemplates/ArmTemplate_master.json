{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "retailadf1232"
		},
		"LS_ADLSGen2_Retail_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stretailkart123.dfs.core.windows.net"
		},
		"LS_AzureKeyVault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-retailkart.vault.azure.net"
		},
		"LS_AzureSQL_Retail_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqldbretailkart.database.windows.net"
		},
		"LS_AzureSQL_Retail_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqldb-retailkart"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "retailadf1232_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_AzureKeyVault_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_AzureKeyVault_properties_typeProperties_baseUrl')]"
					},
					"LS_AzureSQL_Retail_properties_typeProperties_server": {
						"value": "[parameters('LS_AzureSQL_Retail_properties_typeProperties_server')]"
					},
					"LS_AzureSQL_Retail_properties_typeProperties_database": {
						"value": "[parameters('LS_AzureSQL_Retail_properties_typeProperties_database')]"
					},
					"LS_ADLSGen2_Retail_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLSGen2_Retail_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}