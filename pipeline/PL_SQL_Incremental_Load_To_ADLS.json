{
	"name": "PL_SQL_Incremental_Load_To_ADLS",
	"properties": {
		"activities": [
			{
				"name": "Lookup_Old_Watermark",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "@concat(\n'SELECT last_watermark_value FROM dbo.pipeline_watermark WHERE source_table_name = ''',\npipeline().parameters.sourceTableName,\n''''\n)\n",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "DS_AzureSQL_Parameterized",
						"type": "DatasetReference",
						"parameters": {
							"schemaName": "dbo",
							"tableName": "pipeline_watermark"
						}
					}
				}
			}
		],
		"parameters": {
			"sourceSchemaName": {
				"type": "string"
			},
			"sourceTableName": {
				"type": "string"
			},
			"watermarkColumn": {
				"type": "string"
			},
			"targetContainer": {
				"type": "string"
			},
			"targetFolderPath": {
				"type": "string"
			},
			"targetFileName": {
				"type": "string"
			}
		},
		"annotations": []
	}
}